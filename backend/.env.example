APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@localhost:5432/insourcecrew
JWT_SECRET_KEY=replace-with-a-long-random-value
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=14
CORS_ORIGINS=http://localhost:3000
# Supabase (optional): set DATABASE_URL to the Session Pooler PostgreSQL URL.
# Keep SUPABASE_SECRET_KEY out of source control; it is not required while
# InsourceCrew uses its existing JWT authentication.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWKS_URL=
LLM_PROVIDER=fireworks
FIREWORKS_API_KEY=
LLM_MODEL=accounts/fireworks/models/gpt-oss-120b
LLM_BASE_URL=https://api.fireworks.ai/inference/v1
SERPAPI_ENABLED=false
SERPAPI_API_KEY=
DEMO_MODE=true
